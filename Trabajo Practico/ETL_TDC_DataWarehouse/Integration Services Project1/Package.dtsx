          DTS:To="Package\Contenedor FACT_VENTAS\Cargar Ventas Actuales (MySQL)" />
      </DTS:PrecedenceConstraints>
    </DTS:Executable>
    <DTS:Executable
      DTS:refId="Package\Generar y Cargar DIM_TIME"
      DTS:CreationName="Microsoft.ExecuteSQLTask"
      DTS:Description="Tarea Ejecutar SQL"
      DTS:DTSID="{F0ED3865-294E-4A15-9803-CF77A7DEDA33}"
      DTS:ExecutableType="Microsoft.ExecuteSQLTask"
      DTS:LocaleID="-1"
      DTS:ObjectName="Generar y Cargar DIM_TIME"
      DTS:TaskContact="Execute SQL Task; Microsoft Corporation; SQL Server 2025; © 2025 Microsoft Corporation; All Rights Reserved;http://www.microsoft.com/sql/support/default.asp;1"
      DTS:ThreadHint="2">
      <DTS:Variables />
      <DTS:ObjectData>
        <SQLTask:SqlTaskData
          SQLTask:Connection="{BCEA2651-49FA-4687-BA94-3B74675C7F11}"
          SQLTask:SqlStatementSource="USE TDC_DataWarehouse;&#xA;GO&#xA;&#xA;-- Forzamos a que el primer día de la semana sea el Domingo&#xA;SET DATEFIRST 7;&#xA;&#xA;-- Usamos el formato universal YYYYMMDD sin guiones para evitar conflictos de idioma&#xA;DECLARE @StartDate DATE = '20000101';&#xA;DECLARE @EndDate DATE = '20151231';&#xA;&#xA;-- 1. Generamos todos los días secuenciales en memoria&#xA;WITH CalendarioBase AS (&#xA;    SELECT TOP (DATEDIFF(DAY, @StartDate, @EndDate) + 1)&#xA;        DATEADD(DAY, ROW_NUMBER() OVER (ORDER BY (SELECT NULL)) - 1, @StartDate) AS [Fecha]&#xA;    FROM sys.all_objects a CROSS JOIN sys.all_objects b&#xA;),&#xA;-- 2. Limpiamos y transformamos los números flotantes de Excel a fechas reales&#xA;FeriadosLimpios AS (&#xA;    SELECT DISTINCT&#xA;        -- 😎 Cambiamos '1899-12-30' por '18991230' para blindar la conversión en servidores en español&#xA;        DATEADD(day, CAST(CAST(TRIM([DATE]) AS FLOAT) AS INT), '18991230') AS [FechaFeriado]&#xA;    FROM dbo.STG_HOLIDAY&#xA;    WHERE [DATE] IS NOT NULL AND ISNUMERIC(TRIM([DATE])) = 1&#xA;)&#xA;-- 3. Insertamos directo en la dimensión final calculando las propiedades del JSON&#xA;INSERT INTO dbo.DIM_TIME (&#xA;    id_time,&#xA;    YYYYMMDD,&#xA;    [day],&#xA;    day_name,&#xA;    [month],&#xA;    month_day,&#xA;    [year],&#xA;    holiday,&#xA;    weekend,&#xA;    quarter,&#xA;    semester&#xA;)&#xA;SELECT &#xA;    C.[Fecha] AS [id_time],&#xA;    CONVERT(VARCHAR(10), C.[Fecha], 112) AS [YYYYMMDD], &#xA;    DATEPART(DAY, C.[Fecha]) AS [day],&#xA;    DATENAME(WEEKDAY, C.[Fecha]) AS [day_name], &#xA;    DATEPART(MONTH, C.[Fecha]) AS [month],&#xA;    DATENAME(MONTH, C.[Fecha]) AS [month_day], &#xA;    DATEPART(YEAR, C.[Fecha]) AS [year],&#xA;    &#xA;    CASE WHEN F.[FechaFeriado] IS NOT NULL THEN 1 ELSE 0 END AS [holiday],&#xA;    CASE WHEN DATEPART(WEEKDAY, C.[Fecha]) IN (1, 7) THEN 1 ELSE 0 END AS [weekend],&#xA;    DATEPART(QUARTER, C.[Fecha]) AS [quarter],&#xA;    CASE WHEN DATEPART(MONTH, C.[Fecha]) &lt;= 6 THEN 1 ELSE 2 END AS [semester]&#xA;&#xA;FROM CalendarioBase AS C&#xA;LEFT JOIN FeriadosLimpios AS F ON C.[Fecha] = F.[FechaFeriado];" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
      </DTS:ObjectData>
    </DTS:Executable>
    <DTS:Executable
      DTS:refId="Package\Inicializar tabla CUSTOMER"
      DTS:CreationName="Microsoft.ExecuteSQLTask"
      DTS:Description="Tarea Ejecutar SQL"
      DTS:DTSID="{D27F9121-F345-45C5-945A-21693571AD6B}"
      DTS:ExecutableType="Microsoft.ExecuteSQLTask"
      DTS:LocaleID="-1"
      DTS:ObjectName="Inicializar tabla CUSTOMER"
      DTS:TaskContact="Execute SQL Task; Microsoft Corporation; SQL Server 2025; © 2025 Microsoft Corporation; All Rights Reserved;http://www.microsoft.com/sql/support/default.asp;1"
      DTS:ThreadHint="3">
      <DTS:Variables />
      <DTS:ObjectData>
        <SQLTask:SqlTaskData
          SQLTask:Connection="{BCEA2651-49FA-4687-BA94-3B74675C7F11}"
          SQLTask:SqlStatementSource="USE TDC_DataWarehouse;&#xA;GO&#xA;&#xA;-- Borramos versiones previas de pruebas&#xA;IF OBJECT_ID('dbo.DIM_CUSTOMER', 'U') IS NOT NULL DROP TABLE dbo.DIM_CUSTOMER;&#xA;IF OBJECT_ID('dbo.STG_CUSTOMER', 'U') IS NOT NULL DROP TABLE dbo.STG_CUSTOMER;&#xA;&#xA;-- 1. Tabla de Staging Unificada (Con columna para el Tipo de Cliente)&#xA;CREATE TABLE dbo.STG_CUSTOMER (&#xA;    [customer_id] INT NULL,&#xA;    [customer_type] VARCHAR(10) NULL, -- Recibirá 'R' o 'W' desde Visual Studio&#xA;    [full_name] VARCHAR(255) NULL,&#xA;    [birth_date] VARCHAR(255) NULL,  -- VARCHAR obligatorio para tolerar '44/45/1943' o '11j/03/1968'&#xA;    [city] VARCHAR(255) NULL,&#xA;    [state] VARCHAR(255) NULL,&#xA;    [zipcode] VARCHAR(255) NULL&#xA;);&#xA;&#xA;-- 2. Dimensión Final (id_customer como PK Natural sin auto-incremental)&#xA;CREATE TABLE dbo.DIM_CUSTOMER (&#xA;    [id_customer] INT NOT NULL PRIMARY KEY, -- Clave Primaria de los archivos&#xA;    [customer_type] VARCHAR(10) NOT NULL,&#xA;    [full_name] VARCHAR(150) NOT NULL,&#xA;    [birth_date] DATE NOT NULL,&#xA;    [city] VARCHAR(100) NOT NULL,&#xA;    [state] VARCHAR(100) NOT NULL,&#xA;    [zipcode] VARCHAR(20) NOT NULL&#xA;);&#xA;&#xA;BEGIN TRY&#xA;    SET IDENTITY_INSERT dbo.DIM_CUSTOMER ON;&#xA;    INSERT INTO dbo.DIM_CUSTOMER (id_customer, customer_type, full_name, birth_date, state, city, zipcode)&#xA;    VALUES (-1, 'NN', 'Nombre desconocido', '19000101', 'Estado desconocido', 'Ciudad desconocida', 'NNNNN');&#xA;    SET IDENTITY_INSERT dbo.DIM_CUSTOMER OFF;&#xA;END TRY&#xA;BEGIN CATCH&#xA;    INSERT INTO dbo.DIM_CUSTOMER (id_customer, customer_type, full_name, birth_date, state, city, zipcode)&#xA;    VALUES (-1, 'NN', 'Nombre desconocido', '19000101', 'Estado desconocido', 'Ciudad desconocida', 'NNNNN');&#xA;END CATCH;" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
      </DTS:ObjectData>
    </DTS:Executable>
    <DTS:Executable
      DTS:refId="Package\Inicializar tabla EMPLOYEE"
      DTS:CreationName="Microsoft.ExecuteSQLTask"
      DTS:Description="Tarea Ejecutar SQL"
      DTS:DTSID="{A8034941-EDFD-4498-B569-E7E8697BF1BB}"
      DTS:ExecutableType="Microsoft.ExecuteSQLTask"
      DTS:LocaleID="-1"
      DTS:ObjectName="Inicializar tabla EMPLOYEE"
      DTS:TaskContact="Execute SQL Task; Microsoft Corporation; SQL Server 2025; © 2025 Microsoft Corporation; All Rights Reserved;http://www.microsoft.com/sql/support/default.asp;1"
      DTS:ThreadHint="5">
      <DTS:Variables />
      <DTS:ObjectData>
        <SQLTask:SqlTaskData
          SQLTask:Connection="{BCEA2651-49FA-4687-BA94-3B74675C7F11}"
          SQLTask:SqlStatementSource="USE TDC_DataWarehouse;&#xA;GO&#xA;&#xA;IF OBJECT_ID('dbo.DIM_EMPLOYEE', 'U') IS NOT NULL DROP TABLE dbo.DIM_EMPLOYEE;&#xA;IF OBJECT_ID('dbo.STG_EMPLOYEE', 'U') IS NOT NULL DROP TABLE dbo.STG_EMPLOYEE;&#xA;&#xA;-- La tabla intermedia ahora recibe el ID directamente como ENTERO&#xA;CREATE TABLE dbo.STG_EMPLOYEE (&#xA;    [employee_id] INT NULL,        &#xA;    [full_name] VARCHAR(255) NULL,&#xA;    [gender] VARCHAR(255) NULL,&#xA;    [category] VARCHAR(255) NULL,&#xA;    [employment_date] DATE NULL,      &#xA;    [birth_date] DATE NULL,            &#xA;    [education_level] VARCHAR(255) NULL&#xA;);&#xA;&#xA;CREATE TABLE dbo.DIM_EMPLOYEE (&#xA;    [employee_id] INT NOT NULL PRIMARY KEY, &#xA;    [full_name] VARCHAR(150) NOT NULL,&#xA;    [category] VARCHAR(100) NOT NULL,&#xA;    [employment_date] DATE NOT NULL,&#xA;    [birth_date] DATE NOT NULL,&#xA;    [education_level] VARCHAR(100) NOT NULL,&#xA;    [gender] VARCHAR(20) NOT NULL&#xA;);&#xA;&#xA;&#xA;BEGIN TRY&#xA;    SET IDENTITY_INSERT dbo.DIM_EMPLOYEE ON;&#xA;    INSERT INTO dbo.DIM_EMPLOYEE (employee_id, full_name, category, birth_date, employment_date, education_level, gender)&#xA;    VALUES (-1, 'Nombre desconocido', 'Categoria desconocida', '19000101', '19000101', 'Desconocido', 'NN');&#xA;    SET IDENTITY_INSERT dbo.DIM_EMPLOYEE OFF;&#xA;END TRY&#xA;BEGIN CATCH&#xA;    INSERT INTO dbo.DIM_EMPLOYEE (employee_id, full_name, category, birth_date, employment_date, education_level, gender)&#xA;    VALUES (-1, 'Nombre desconocido', 'Categoria desconocida', '19000101', '19000101', 'Desconocido', 'NN');&#xA;END CATCH;" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
      </DTS:ObjectData>
    </DTS:Executable>
    <DTS:Executable
      DTS:refId="Package\Inicializar tabla Productos"
      DTS:CreationName="Microsoft.ExecuteSQLTask"
      DTS:Description="Tarea Ejecutar SQL"
      DTS:DTSID="{E3B11024-9EF9-4504-ABA5-36FD4100B6A3}"
      DTS:ExecutableType="Microsoft.ExecuteSQLTask"
      DTS:LocaleID="-1"
      DTS:ObjectName="Inicializar tabla Productos"
      DTS:TaskContact="Execute SQL Task; Microsoft Corporation; SQL Server 2025; © 2025 Microsoft Corporation; All Rights Reserved;http://www.microsoft.com/sql/support/default.asp;1"
      DTS:ThreadHint="0">
      <DTS:Variables />
      <DTS:ObjectData>
        <SQLTask:SqlTaskData
          SQLTask:Connection="{BCEA2651-49FA-4687-BA94-3B74675C7F11}"
          SQLTask:SqlStatementSource="USE TDC_DataWarehouse;&#xA;GO&#xA;&#xA;-- Borramos todo lo viejo por si acaso&#xA;IF OBJECT_ID('dbo.DIM_PROD', 'U') IS NOT NULL DROP TABLE dbo.DIM_PROD;&#xA;IF OBJECT_ID('dbo.STG_PRODUCT', 'U') IS NOT NULL DROP TABLE dbo.STG_PRODUCT;&#xA;IF OBJECT_ID('dbo.STG_PRICE', 'U') IS NOT NULL DROP TABLE dbo.STG_PRICE;&#xA;&#xA;-- Creamos Staging para el archivo plano de texto&#xA;CREATE TABLE dbo.STG_PRODUCT (&#xA;    [PRODUCT_ID] INT NULL,&#xA;    [DETAIL] VARCHAR(250) NULL,&#xA;    [PACKAGE] VARCHAR(250) NULL&#xA;);&#xA;&#xA;-- Creamos Staging para los precios históricos de MySQL&#xA;CREATE TABLE dbo.STG_PRICE (&#xA;    [product_id] INT NULL,&#xA;[date] DATETIME NULL,&#xA;[price] FLOAT NULL&#xA;);&#xA;&#xA;-- Creamos la DIM_PROD final EXACTAMENTE igual a tu JSON&#xA;CREATE TABLE dbo.DIM_PROD (&#xA;    [id_dim_prod] INT IDENTITY(1,1) NOT NULL PRIMARY KEY, -- Clave subrogada automática&#xA;    [product_id] INT NOT NULL,&#xA;    [name] VARCHAR(100) NOT NULL,&#xA;    [category_ml] VARCHAR(100) NOT NULL,&#xA;    [packaging] VARCHAR(100) NOT NULL,&#xA;    [capacity] INT NOT NULL,&#xA;    [diet] BIT NOT NULL,                              -- BOOLEAN en SQL es BIT&#xA;    [price] FLOAT NOT NULL,&#xA;    [discontinued] BIT NOT NULL,                      -- BOOLEAN&#xA;    [price_from] DATETIME NOT NULL,&#xA;    [price_until] DATETIME NULL                       -- Puede ser NULL si es el precio actual&#xA;);&#xA;&#xA;-- Clavamos el registro -1 apenas nace la tabla&#xA;BEGIN TRY&#xA;    SET IDENTITY_INSERT dbo.DIM_PROD ON;&#xA;    INSERT INTO dbo.DIM_PROD (id_dim_prod, product_id, name, category_ml, packaging, capacity, diet, price, discontinued, price_from, price_until)&#xA;    VALUES (-1, -1, 'Nombre desconocido', 'Categoria desconocida', 'Desconocido', -1, 0, -1, 0, '20000101', NULL);&#xA;    SET IDENTITY_INSERT dbo.DIM_PROD OFF;&#xA;END TRY&#xA;BEGIN CATCH&#xA;    INSERT INTO dbo.DIM_PROD (id_dim_prod, product_id, name, category_ml, packaging, capacity, diet, price, discontinued, price_from, price_until)&#xA;    VALUES (-1, -1, 'Nombre desconocido', 'Categoria desconocida', 'Desconocido', -1, 0, -1, 0, '20000101', NULL);&#xA;END CATCH;" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
      </DTS:ObjectData>
    </DTS:Executable>
    <DTS:Executable
      DTS:refId="Package\Inicializar Tablas de DISCOUNTS"
      DTS:CreationName="Microsoft.ExecuteSQLTask"
      DTS:Description="Tarea Ejecutar SQL"
      DTS:DTSID="{1E851408-F354-45F1-B34C-C3364AA7C805}"
      DTS:ExecutableType="Microsoft.ExecuteSQLTask"
      DTS:LocaleID="-1"
      DTS:ObjectName="Inicializar Tablas de DISCOUNTS"
      DTS:TaskContact="Execute SQL Task; Microsoft Corporation; SQL Server 2025; © 2025 Microsoft Corporation; All Rights Reserved;http://www.microsoft.com/sql/support/default.asp;1"
      DTS:ThreadHint="4">
      <DTS:Variables />
      <DTS:ObjectData>
        <SQLTask:SqlTaskData
          SQLTask:Connection="{BCEA2651-49FA-4687-BA94-3B74675C7F11}"
          SQLTask:SqlStatementSource="USE TDC_DataWarehouse;&#xA;GO&#xA;&#xA;-- Borramos las tablas si ya existían de una corrida previa&#xA;IF OBJECT_ID('dbo.DIM_DISCOUNT', 'U') IS NOT NULL DROP TABLE dbo.DIM_DISCOUNT;&#xA;IF OBJECT_ID('dbo.STG_DISCOUNT', 'U') IS NOT NULL DROP TABLE dbo.STG_DISCOUNT;&#xA;&#xA;-- 1. Tabla de Staging (Espejo fiel de la nube de MySQL)&#xA;CREATE TABLE dbo.STG_DISCOUNT (&#xA;    [discount_id] INT NULL,&#xA;    [from] DATE NULL,&#xA;    [until] DATE NULL,&#xA;    [total_billing] FLOAT NULL,&#xA;    [percentage] FLOAT NULL&#xA;);&#xA;&#xA;-- 2. Dimensión Final usa el ID original como PK&#xA;CREATE TABLE dbo.DIM_DISCOUNT (&#xA;    [id_discount] INT NOT NULL PRIMARY KEY, -- PK Natural (Cargada desde el origen, sin auto-incremental)&#xA;    [min_total_sale] FLOAT NOT NULL,       &#xA;    [discount_percentage] FLOAT NOT NULL,   &#xA;    [from] DATE NOT NULL,&#xA;    [until] DATE NULL&#xA;);&#xA;&#xA;-- ... (Acá va tu DROP y CREATE TABLE de DIM_DISCOUNT) ...&#xA;&#xA;INSERT INTO dbo.DIM_DISCOUNT (id_discount, min_total_sale, discount_percentage, [from], [until])&#xA;VALUES (-1, 0.0, 0.0, '20000101', NULL);" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
      </DTS:ObjectData>
    </DTS:Executable>
    <DTS:Executable
      DTS:refId="Package\Inicializar tablas de REGIONS"
      DTS:CreationName="Microsoft.ExecuteSQLTask"
      DTS:Description="Tarea Ejecutar SQL"
      DTS:DTSID="{6C9E6771-B919-4366-810B-985B66D636D4}"
      DTS:ExecutableType="Microsoft.ExecuteSQLTask"
      DTS:LocaleID="-1"
      DTS:ObjectName="Inicializar tablas de REGIONS"
      DTS:TaskContact="Execute SQL Task; Microsoft Corporation; SQL Server 2025; © 2025 Microsoft Corporation; All Rights Reserved;http://www.microsoft.com/sql/support/default.asp;1"
      DTS:ThreadHint="1">
      <DTS:Variables />
      <DTS:ObjectData>
        <SQLTask:SqlTaskData
          SQLTask:Connection="{BCEA2651-49FA-4687-BA94-3B74675C7F11}"
          SQLTask:SqlStatementSource="USE TDC_DataWarehouse;&#xA;GO&#xA;&#xA;-- Borramos las tablas si ya existían de una corrida previa&#xA;IF OBJECT_ID('dbo.DIM_GEO', 'U') IS NOT NULL DROP TABLE dbo.DIM_GEO;&#xA;IF OBJECT_ID('dbo.STG_GEO', 'U') IS NOT NULL DROP TABLE dbo.STG_GEO;&#xA;&#xA;-- 1. Tabla de Staging (Espejo para absorber el archivo de texto plano)&#xA;CREATE TABLE dbo.STG_GEO (&#xA;    [region] VARCHAR(255) NULL,&#xA;    [state] VARCHAR(255) NULL,&#xA;    [city] VARCHAR(255) NULL,&#xA;    [zipcode] VARCHAR(255) NULL&#xA;);&#xA;&#xA;-- 2. Dimensión Final (Con id_geo como AUTO-INCREMENTAL e incluyendo la columna City)&#xA;CREATE TABLE dbo.DIM_GEO (&#xA;    [id_geo] INT IDENTITY(1,1) NOT NULL PRIMARY KEY, -- Clave subrogada automática&#xA;    [region] VARCHAR(100) NOT NULL,&#xA;    [state] VARCHAR(100) NOT NULL,&#xA;    [city] VARCHAR(100) NOT NULL,&#xA;    [zipcode] VARCHAR(20) NOT NULL&#xA;);&#xA;&#xA;BEGIN TRY&#xA;    SET IDENTITY_INSERT dbo.DIM_GEO ON;&#xA;    INSERT INTO dbo.DIM_GEO (id_geo, region, state, city, zipcode)&#xA;    VALUES (-1, 'Region desconocida', 'Estado desconocido', 'Ciudad desconocida', 'NNNNN');&#xA;    SET IDENTITY_INSERT dbo.DIM_GEO OFF;&#xA;END TRY&#xA;BEGIN CATCH&#xA;    INSERT INTO dbo.DIM_GEO (id_geo, region, state, city, zipcode)&#xA;    VALUES (-1, 'Region desconocida', 'Estado desconocido', 'Ciudad desconocida', 'NNNNN');&#xA;END CATCH;" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
      </DTS:ObjectData>
    </DTS:Executable>
    <DTS:Executable
      DTS:refId="Package\Inicializar tablas de TIME"
      DTS:CreationName="Microsoft.ExecuteSQLTask"
      DTS:DelayValidation="True"
      DTS:Description="Tarea Ejecutar SQL"
      DTS:DTSID="{BD4B6033-4955-41D9-A074-C546AFF996F1}"
      DTS:ExecutableType="Microsoft.ExecuteSQLTask"
      DTS:LocaleID="-1"
      DTS:ObjectName="Inicializar tablas de TIME"
      DTS:TaskContact="Execute SQL Task; Microsoft Corporation; SQL Server 2025; © 2025 Microsoft Corporation; All Rights Reserved;http://www.microsoft.com/sql/support/default.asp;1"
      DTS:ThreadHint="2">
      <DTS:Variables />
      <DTS:ObjectData>
        <SQLTask:SqlTaskData
          SQLTask:Connection="{BCEA2651-49FA-4687-BA94-3B74675C7F11}"
          SQLTask:SqlStatementSource="USE TDC_DataWarehouse;&#xA;GO&#xA;&#xA;IF OBJECT_ID('dbo.DIM_TIME', 'U') IS NOT NULL DROP TABLE dbo.DIM_TIME;&#xA;IF OBJECT_ID('dbo.STG_HOLIDAY', 'U') IS NOT NULL DROP TABLE dbo.STG_HOLIDAY;&#xA;&#xA;-- 1. Tabla de Staging para absorber el CSV de feriados crudo&#xA;CREATE TABLE dbo.STG_HOLIDAY (&#xA;    [DATE] VARCHAR(100) NULL,&#xA;    [HOLIDAY] VARCHAR(255) NULL&#xA;);&#xA;&#xA;-- 2. Dimensión Final según tu JSON (BOOLEAN mapea a BIT en SQL Server)&#xA;CREATE TABLE dbo.DIM_TIME (&#xA;    [id_time] DATE NOT NULL PRIMARY KEY,&#xA;    [YYYYMMDD] VARCHAR(20) NOT NULL,&#xA;    [day] INT NOT NULL,&#xA;    [day_name] VARCHAR(30) NOT NULL,&#xA;    [month] INT NOT NULL,&#xA;    [month_day] VARCHAR(30) NOT NULL, -- Almacenará el nombre del mes descriptivo&#xA;    [year] INT NOT NULL,&#xA;    [holiday] BIT NOT NULL,&#xA;    [weekend] BIT NOT NULL,&#xA;    [quarter] INT NOT NULL,&#xA;    [semester] INT NOT NULL&#xA;);&#xA;&#xA;-- Inyectamos el miembro por defecto respetando de forma estricta los NOT NULL&#xA;IF NOT EXISTS (SELECT 1 FROM dbo.DIM_TIME WHERE id_time = '19000101')&#xA;BEGIN&#xA;    INSERT INTO dbo.DIM_TIME (&#xA;        [id_time], &#xA;        [YYYYMMDD], &#xA;        [day], &#xA;        [day_name], &#xA;        [month], &#xA;        [month_day], &#xA;        [year], &#xA;        [holiday], &#xA;        [weekend], &#xA;        [quarter], &#xA;        [semester]&#xA;    )&#xA;    VALUES (&#xA;        '19000101',           -- id_time (PK)&#xA;        '19000101',           -- YYYYMMDD&#xA;        -1,                    -- day&#xA;        'No Especificado',    -- day_name&#xA;        -1,                    -- month&#xA;        'No Especificado',    -- month_day&#xA;        1900,                 -- year&#xA;        0,                    -- holiday (BIT - Falso)&#xA;        0,                    -- weekend (BIT - Falso)&#xA;        -1,                    -- quarter&#xA;        -1                     -- semester&#xA;    );&#xA;END;" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
      </DTS:ObjectData>
    </DTS:Executable>
    <DTS:Executable
      DTS:refId="Package\Transformar y Cargar DIM_CUSTOMER"
      DTS:CreationName="Microsoft.ExecuteSQLTask"
      DTS:Description="Tarea Ejecutar SQL"
      DTS:DTSID="{D55A6C06-CA78-4487-8B90-13E67145FD87}"
      DTS:ExecutableType="Microsoft.ExecuteSQLTask"
      DTS:LocaleID="-1"
      DTS:ObjectName="Transformar y Cargar DIM_CUSTOMER"
      DTS:TaskContact="Execute SQL Task; Microsoft Corporation; SQL Server 2025; © 2025 Microsoft Corporation; All Rights Reserved;http://www.microsoft.com/sql/support/default.asp;1"
      DTS:ThreadHint="3">
      <DTS:Variables />
      <DTS:ObjectData>
        <SQLTask:SqlTaskData
          SQLTask:Connection="{BCEA2651-49FA-4687-BA94-3B74675C7F11}"
          SQLTask:SqlStatementSource="USE TDC_DataWarehouse;&#xA;GO&#xA;&#xA;-- 1. Primero creamos una vista temporal en memoria (CTE) para limpiar los caracteres basura&#xA;WITH ClientesLimpios AS (&#xA;    SELECT &#xA;        [customer_id],&#xA;        [customer_type],&#xA;        [full_name],&#xA;        [city],&#xA;        [state],&#xA;        [zipcode],&#xA;        -- Reemplazamos las letras 'j' y los asteriscos '*' por nada en el texto&#xA;        REPLACE(REPLACE(TRIM([birth_date]), 'j', ''), '*', '') AS [birth_date_raw]&#xA;    FROM dbo.STG_CUSTOMER&#xA;)&#xA;-- 2. Ahora insertamos en la dimensión aplicando las reglas analíticas&#xA;INSERT INTO dbo.DIM_CUSTOMER (&#xA;    id_customer,&#xA;    customer_type,&#xA;    full_name,&#xA;    birth_date,&#xA;    city,&#xA;    state,&#xA;    zipcode&#xA;)&#xA;SELECT &#xA;    [customer_id] AS [id_customer],&#xA;    [customer_type],&#xA;    TRIM([full_name]) AS [full_name],&#xA;    &#xA;    --  TRATAMIENTO AVANZADO DE FECHAS ROTAS&#xA;    CASE &#xA;        -- Regla 1: Si la fecha ya es válida (o se arregló quitando la 'j' o el '*'), la convertimos directo&#xA;        WHEN TRY_CONVERT(DATE, [birth_date_raw], 101) IS NOT NULL &#xA;            THEN TRY_CONVERT(DATE, [birth_date_raw], 101)&#xA;        &#xA;        -- Regla 2: Si el mes/día es un invento (como 44/45/1943 o 10/50/1964) pero el año final es un número válido&#xA;        WHEN ISNUMERIC(RIGHT([birth_date_raw], 4)) = 1 &#xA;             AND CAST(RIGHT([birth_date_raw], 4) AS INT) BETWEEN 1900 AND 2026&#xA;            -- Fabricamos el 1 de Enero de ese mismo año para conservar la edad aproximada del cliente&#xA;            THEN TRY_CONVERT(DATE, RIGHT([birth_date_raw], 4) + '-01-01')&#xA;        &#xA;        -- Regla 3: Si el dato es un desastre irrecuperable de punta a punta, recién ahí cae en el default absoluto&#xA;        ELSE '1900-01-01'&#xA;    END AS [birth_date],&#xA;    &#xA;    TRIM([city]) AS [city],&#xA;    TRIM([state]) AS [state],&#xA;    TRIM([zipcode]) AS [zipcode]&#xA;FROM ClientesLimpios;" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
      </DTS:ObjectData>
    </DTS:Executable>
    <DTS:Executable
      DTS:refId="Package\Transformar y Cargar DIM_DISCOUNT"
      DTS:CreationName="Microsoft.ExecuteSQLTask"
      DTS:Description="Tarea Ejecutar SQL"
      DTS:DTSID="{F6CDC93A-4200-477C-91A2-0149DDC3F13F}"
      DTS:ExecutableType="Microsoft.ExecuteSQLTask"
      DTS:LocaleID="-1"
      DTS:ObjectName="Transformar y Cargar DIM_DISCOUNT"
      DTS:TaskContact="Execute SQL Task; Microsoft Corporation; SQL Server 2025; © 2025 Microsoft Corporation; All Rights Reserved;http://www.microsoft.com/sql/support/default.asp;1"
      DTS:ThreadHint="4">
      <DTS:Variables />
      <DTS:ObjectData>
        <SQLTask:SqlTaskData
          SQLTask:Connection="{BCEA2651-49FA-4687-BA94-3B74675C7F11}"
          SQLTask:SqlStatementSource="USE TDC_DataWarehouse;&#xA;GO&#xA;&#xA;-- Como especificaste que id_discount NO es subrogada, le insertamos el ID original directamente&#xA;INSERT INTO dbo.DIM_DISCOUNT (&#xA;    id_discount,&#xA;    min_total_sale,&#xA;    discount_percentage,&#xA;    [from],&#xA;    [until]&#xA;)&#xA;SELECT &#xA;    [discount_id] AS [id_discount],         -- Tu PK natural mapeada directamente&#xA;    [total_billing] AS [min_total_sale],    &#xA;    [percentage] AS [discount_percentage],   &#xA;    [from],                                 -- Usamos corchetes porque FROM es palabra reservada en SQL Server&#xA;    [until]&#xA;FROM dbo.STG_DISCOUNT;" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
      </DTS:ObjectData>
    </DTS:Executable>
    <DTS:Executable
      DTS:refId="Package\Transformar y Cargar DIM_EMPLOYEE"
      DTS:CreationName="Microsoft.ExecuteSQLTask"
      DTS:Description="Tarea Ejecutar SQL"
      DTS:DTSID="{8F1AC3B3-F222-4CDD-90E4-E0A44FEC9453}"
      DTS:ExecutableType="Microsoft.ExecuteSQLTask"
      DTS:LocaleID="-1"
      DTS:ObjectName="Transformar y Cargar DIM_EMPLOYEE"
      DTS:TaskContact="Execute SQL Task; Microsoft Corporation; SQL Server 2025; © 2025 Microsoft Corporation; All Rights Reserved;http://www.microsoft.com/sql/support/default.asp;1"
      DTS:ThreadHint="5">
      <DTS:Variables />
      <DTS:ObjectData>
        <SQLTask:SqlTaskData
          SQLTask:Connection="{BCEA2651-49FA-4687-BA94-3B74675C7F11}"
          SQLTask:SqlStatementSource="USE TDC_DataWarehouse;&#xA;GO&#xA;&#xA;INSERT INTO dbo.DIM_EMPLOYEE (&#xA;    employee_id,&#xA;    full_name,&#xA;    gender,&#xA;    category,&#xA;    employment_date,&#xA;    birth_date,&#xA;    education_level&#xA;)&#xA;SELECT &#xA;    [employee_id],&#xA;    TRIM([full_name]),&#xA;    TRIM([gender]),&#xA;    TRIM([category]),&#xA;    [employment_date], &#xA;    [birth_date],        &#xA;    TRIM([education_level])&#xA;FROM dbo.STG_EMPLOYEE;" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
      </DTS:ObjectData>
    </DTS:Executable>
    <DTS:Executable
      DTS:refId="Package\Transformar y Cargar DIM_GEO"
      DTS:CreationName="Microsoft.ExecuteSQLTask"
      DTS:Description="Tarea Ejecutar SQL"
      DTS:DTSID="{6EB1E130-6C82-4672-97E4-A20EA9242323}"
      DTS:ExecutableType="Microsoft.ExecuteSQLTask"
      DTS:LocaleID="-1"
      DTS:ObjectName="Transformar y Cargar DIM_GEO"
      DTS:TaskContact="Execute SQL Task; Microsoft Corporation; SQL Server 2025; © 2025 Microsoft Corporation; All Rights Reserved;http://www.microsoft.com/sql/support/default.asp;1"
      DTS:ThreadHint="1">
      <DTS:Variables />
      <DTS:ObjectData>
        <SQLTask:SqlTaskData
          SQLTask:Connection="{BCEA2651-49FA-4687-BA94-3B74675C7F11}"
          SQLTask:SqlStatementSource="USE TDC_DataWarehouse;&#xA;GO&#xA;&#xA;-- Usamos DISTINCT por si el archivo de texto llega a tener registros de zonas duplicados&#xA;INSERT INTO dbo.DIM_GEO (&#xA;    region,&#xA;    state,&#xA;    city,&#xA;    zipcode&#xA;)&#xA;SELECT DISTINCT&#xA;    TRIM([region]) AS [region],&#xA;    TRIM([state]) AS [state],&#xA;    TRIM([city]) AS [city],&#xA;    TRIM([zipcode]) AS [zipcode]&#xA;FROM dbo.STG_GEO&#xA;WHERE [zipcode] IS NOT NULL AND TRIM([zipcode]) &lt;&gt; '';" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
      </DTS:ObjectData>
    </DTS:Executable>
    <DTS:Executable
      DTS:refId="Package\Transformar y cargar DIM_PROD"
      DTS:CreationName="Microsoft.ExecuteSQLTask"
      DTS:Description="Tarea Ejecutar SQL"
      DTS:DTSID="{60D01865-BEAC-408C-A371-69EB917164D0}"
      DTS:ExecutableType="Microsoft.ExecuteSQLTask"
      DTS:LocaleID="-1"
      DTS:ObjectName="Transformar y cargar DIM_PROD"
      DTS:TaskContact="Execute SQL Task; Microsoft Corporation; SQL Server 2025; © 2025 Microsoft Corporation; All Rights Reserved;http://www.microsoft.com/sql/support/default.asp;1"
      DTS:ThreadHint="0">
      <DTS:Variables />
      <DTS:ObjectData>
        <SQLTask:SqlTaskData
          SQLTask:Connection="{BCEA2651-49FA-4687-BA94-3B74675C7F11}"
          SQLTask:SqlStatementSource="USE TDC_DataWarehouse;&#xA;GO&#xA;&#xA;-- Creamos la estructura temporal para calcular vigencias de precios históricos con LEAD&#xA;WITH PreciosCalculados AS (&#xA;    SELECT &#xA;        [product_id],&#xA;        [price],&#xA;        [date] AS [price_from],&#xA;        LEAD([date]) OVER (PARTITION BY [product_id] ORDER BY [date]) AS [price_until]&#xA;    FROM dbo.STG_PRICE&#xA;)&#xA;INSERT INTO dbo.DIM_PROD (&#xA;    product_id, &#xA;    name, &#xA;    category_ml, &#xA;    packaging, &#xA;    capacity, &#xA;    diet, &#xA;    price, &#xA;    discontinued, &#xA;    price_from, &#xA;    price_until&#xA;)&#xA;SELECT &#xA;    TXT.[PRODUCT_ID] AS [product_id],&#xA;    TRIM(TXT.[DETAIL]) AS [name],&#xA;    &#xA;    -- 1. Nueva clasificación de categorías con el ajuste que pediste&#xA;    CASE &#xA;        WHEN TXT.[DETAIL] LIKE '%Root Beer%' OR TXT.[DETAIL] LIKE '%Birch Beer%' THEN 'Beers NO Alcohol'&#xA;        WHEN TXT.[DETAIL] LIKE '%Trappiste%' OR TXT.[DETAIL] LIKE '%Orval%' THEN 'Beers'&#xA;        WHEN TXT.[DETAIL] LIKE '%Energy drink%' THEN 'Energy'&#xA;        WHEN TXT.[DETAIL] LIKE '%juice%' THEN 'Juices'&#xA;        ELSE 'Sodas' -- Acá van a caer Kool Cola y Cream Soda&#xA;    END AS [category_ml],&#xA;    &#xA;    -- 2. Regla de Envase (si dice 'can' es Lata, si no, Botella)&#xA;    CASE &#xA;        WHEN TXT.[PACKAGE] LIKE '%can%' THEN 'Can'&#xA;        ELSE 'Bottle'&#xA;    END AS [packaging],&#xA;    &#xA;    -- 3. Mapeo exacto de Capacidades a centímetros cúbicos enteros&#xA;    CASE &#xA;        WHEN TXT.[PACKAGE] LIKE '%1 Liter%' THEN 1000&#xA;        WHEN TXT.[PACKAGE] LIKE '%2 Liter%' THEN 2000&#xA;        WHEN TXT.[PACKAGE] LIKE '%500 cm3%' THEN 500&#xA;        WHEN TXT.[PACKAGE] LIKE '%670 cm3%' THEN 670&#xA;        WHEN TXT.[PACKAGE] LIKE '%330 cm3%' THEN 330&#xA;        ELSE 1000 &#xA;    END AS [capacity],&#xA;    &#xA;    -- 4. Detección de productos Diet/Light (1 = True, 0 = False)&#xA;    CASE &#xA;        WHEN TXT.[DETAIL] LIKE '%Diet%' THEN 1&#xA;        ELSE 0&#xA;    END AS [diet],&#xA;    &#xA;    -- 5. Datos financieros y vigencias calculadas desde el Staging de MySQL&#xA;    PRC.[price] AS [price],&#xA;    0 AS [discontinued],&#xA;    PRC.[price_from] AS [price_from],&#xA;    PRC.[price_until] AS [price_until]&#xA;&#xA;FROM dbo.STG_PRODUCT AS TXT&#xA;INNER JOIN PreciosCalculados AS PRC ON TXT.[PRODUCT_ID] = PRC.[product_id];" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
      </DTS:ObjectData>
    </DTS:Executable>
  </DTS:Executables>
