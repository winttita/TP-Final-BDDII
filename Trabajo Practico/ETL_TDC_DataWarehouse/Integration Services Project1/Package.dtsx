              SQLTask:Connection="{BCEA2651-49FA-4687-BA94-3B74675C7F11}"
              SQLTask:SqlStatementSource="USE TDC_DataWarehouse;&#xA;GO&#xA;&#xA;IF OBJECT_ID('dbo.FACT_stock', 'U') IS NOT NULL DROP TABLE dbo.FACT_stock;&#xA;IF OBJECT_ID('dbo.STG_STOCK', 'U') IS NOT NULL DROP TABLE dbo.STG_STOCK;&#xA;&#xA;-- Staging con ID de orden para asegurar el acumulado progresivo&#xA;CREATE TABLE dbo.STG_STOCK (&#xA;    [id_stg] INT IDENTITY(1,1) NOT NULL PRIMARY KEY,&#xA;    [product_id] INT NULL,&#xA;    [date_str] VARCHAR(100) NULL,&#xA;    [variation] INT NULL&#xA;);&#xA;&#xA;-- Tabla de Hechos Definitiva (Estricta al JSON)&#xA;CREATE TABLE dbo.FACT_stock (&#xA;    [id_stock] INT IDENTITY(1,1) NOT NULL PRIMARY KEY,&#xA;    [id_product] INT NOT NULL,  &#xA;    [id_time] DATE NOT NULL,     &#xA;    [variation] INT NOT NULL,&#xA;    [quantity_acum] INT NOT NULL&#xA;);" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
