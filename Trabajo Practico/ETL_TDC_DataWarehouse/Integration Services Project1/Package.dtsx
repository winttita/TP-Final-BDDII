    </DTS:Executable>
    <DTS:Executable
      DTS:refId="Package\Crear Restricciones FK Finales"
      DTS:CreationName="Microsoft.ExecuteSQLTask"
      DTS:Description="Tarea Ejecutar SQL"
      DTS:DTSID="{5925827F-0715-43D5-807A-D195E64735A1}"
      DTS:ExecutableType="Microsoft.ExecuteSQLTask"
      DTS:LocaleID="-1"
      DTS:ObjectName="Crear Restricciones FK Finales"
      DTS:TaskContact="Execute SQL Task; Microsoft Corporation; SQL Server 2025; © 2025 Microsoft Corporation; All Rights Reserved;http://www.microsoft.com/sql/support/default.asp;1"
      DTS:ThreadHint="0">
      <DTS:Variables />
      <DTS:ObjectData>
        <SQLTask:SqlTaskData
          SQLTask:Connection="{BCEA2651-49FA-4687-BA94-3B74675C7F11}"
          SQLTask:SqlStatementSource="USE TDC_DataWarehouse;&#xA;GO&#xA;&#xA;-- ===================================================================&#xA;-- 1. LIMPIEZA PREVIA DE RESTRICCIONES VIEJAS&#xA;-- ===================================================================&#xA;IF EXISTS (SELECT 1 FROM sys.foreign_keys WHERE name = 'FK_FACT_VENTAS_DIM_PROD') &#xA;    ALTER TABLE dbo.FACT_VENTAS DROP CONSTRAINT FK_FACT_VENTAS_DIM_PROD;&#xA;&#xA;IF EXISTS (SELECT 1 FROM sys.foreign_keys WHERE name = 'FK_FACT_VENTAS_DIM_CUSTOMER') &#xA;    ALTER TABLE dbo.FACT_VENTAS DROP CONSTRAINT FK_FACT_VENTAS_DIM_CUSTOMER;&#xA;&#xA;IF EXISTS (SELECT 1 FROM sys.foreign_keys WHERE name = 'FK_FACT_VENTAS_DIM_EMPLOYEE') &#xA;    ALTER TABLE dbo.FACT_VENTAS DROP CONSTRAINT FK_FACT_VENTAS_DIM_EMPLOYEE;&#xA;&#xA;IF EXISTS (SELECT 1 FROM sys.foreign_keys WHERE name = 'FK_FACT_VENTAS_DIM_TIME') &#xA;    ALTER TABLE dbo.FACT_VENTAS DROP CONSTRAINT FK_FACT_VENTAS_DIM_TIME;&#xA;&#xA;IF EXISTS (SELECT 1 FROM sys.foreign_keys WHERE name = 'FK_FACT_VENTAS_DIM_GEO') &#xA;    ALTER TABLE dbo.FACT_VENTAS DROP CONSTRAINT FK_FACT_VENTAS_DIM_GEO;&#xA;&#xA;IF EXISTS (SELECT 1 FROM sys.foreign_keys WHERE name = 'FK_FACT_VENTAS_DIM_DISCOUNT') &#xA;    ALTER TABLE dbo.FACT_VENTAS DROP CONSTRAINT FK_FACT_VENTAS_DIM_DISCOUNT;&#xA;&#xA;IF EXISTS (SELECT 1 FROM sys.foreign_keys WHERE name = 'FK_FACT_STOCK_DIM_TIME') &#xA;    ALTER TABLE dbo.FACT_stock DROP CONSTRAINT FK_FACT_STOCK_DIM_TIME;&#xA;&#xA;&#xA;-- ===================================================================&#xA;-- 2. CREACIÓN DE RESTRICCIONES PARA FACT_VENTAS&#xA;-- ===================================================================&#xA;ALTER TABLE dbo.FACT_VENTAS ADD CONSTRAINT FK_FACT_VENTAS_DIM_PROD&#xA;FOREIGN KEY (id_prod) REFERENCES dbo.DIM_PROD (id_dim_prod);&#xA;&#xA;ALTER TABLE dbo.FACT_VENTAS ADD CONSTRAINT FK_FACT_VENTAS_DIM_CUSTOMER&#xA;FOREIGN KEY (id_customer) REFERENCES dbo.DIM_CUSTOMER (id_customer);&#xA;&#xA;ALTER TABLE dbo.FACT_VENTAS ADD CONSTRAINT FK_FACT_VENTAS_DIM_EMPLOYEE&#xA;FOREIGN KEY (id_employee) REFERENCES dbo.DIM_EMPLOYEE (id_employee);&#xA;&#xA;ALTER TABLE dbo.FACT_VENTAS ADD CONSTRAINT FK_FACT_VENTAS_DIM_TIME&#xA;FOREIGN KEY (id_time) REFERENCES dbo.DIM_TIME (id_time);&#xA;&#xA;ALTER TABLE dbo.FACT_VENTAS ADD CONSTRAINT FK_FACT_VENTAS_DIM_GEO&#xA;FOREIGN KEY (id_geo) REFERENCES dbo.DIM_GEO (id_geo);&#xA;&#xA;ALTER TABLE dbo.FACT_VENTAS ADD CONSTRAINT FK_FACT_VENTAS_DIM_DISCOUNT&#xA;FOREIGN KEY (id_discount) REFERENCES dbo.DIM_DISCOUNT (id_discount);&#xA;&#xA;&#xA;-- ===================================================================&#xA;-- 3. CREACIÓN DE RESTRICCIONES PARA FACT_STOCK&#xA;-- ===================================================================&#xA;&#xA;-- 🌟 Sincronizamos el stock con la dimensión de Tiempo (Crucial para los filtros por Año/Mes)&#xA;ALTER TABLE dbo.FACT_stock&#xA;ADD CONSTRAINT FK_FACT_STOCK_DIM_TIME&#xA;FOREIGN KEY (id_time) REFERENCES dbo.DIM_TIME (id_time);&#xA;&#xA;-- 💡 NOTA PARA LA DEFENSA: La relación física FACT_stock -&gt; DIM_PROD por 'product_id' &#xA;-- no se crea mediante CONSTRAINT debido a que 'product_id' no es la Clave Primaria en la dimensión.&#xA;-- Se resolverá de forma lógica y directa en el modelo de Power BI." xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
      </DTS:ObjectData>
    </DTS:Executable>
    <DTS:Executable
      DTS:refId="Package\Eliminar Restricciones FK Iniciales"
      DTS:CreationName="Microsoft.ExecuteSQLTask"
      DTS:Description="Tarea Ejecutar SQL"
      DTS:DTSID="{8BA36EED-7066-411F-8075-70C53F9F354B}"
      DTS:ExecutableType="Microsoft.ExecuteSQLTask"
      DTS:LocaleID="-1"
      DTS:ObjectName="Eliminar Restricciones FK Iniciales"
      DTS:TaskContact="Execute SQL Task; Microsoft Corporation; SQL Server 2025; © 2025 Microsoft Corporation; All Rights Reserved;http://www.microsoft.com/sql/support/default.asp;1"
      DTS:ThreadHint="0">
      <DTS:Variables />
      <DTS:ObjectData>
        <SQLTask:SqlTaskData
          SQLTask:Connection="{BCEA2651-49FA-4687-BA94-3B74675C7F11}"
          SQLTask:SqlStatementSource="USE TDC_DataWarehouse;&#xA;GO&#xA;&#xA;-- Rompemos las restricciones para que los DROP TABLE de las inicializaciones no reboten&#xA;IF EXISTS (SELECT 1 FROM sys.foreign_keys WHERE name = 'FK_FACT_VENTAS_DIM_PROD') &#xA;    ALTER TABLE dbo.FACT_VENTAS DROP CONSTRAINT FK_FACT_VENTAS_DIM_PROD;&#xA;&#xA;IF EXISTS (SELECT 1 FROM sys.foreign_keys WHERE name = 'FK_FACT_VENTAS_DIM_CUSTOMER') &#xA;    ALTER TABLE dbo.FACT_VENTAS DROP CONSTRAINT FK_FACT_VENTAS_DIM_CUSTOMER;&#xA;&#xA;IF EXISTS (SELECT 1 FROM sys.foreign_keys WHERE name = 'FK_FACT_VENTAS_DIM_EMPLOYEE') &#xA;    ALTER TABLE dbo.FACT_VENTAS DROP CONSTRAINT FK_FACT_VENTAS_DIM_EMPLOYEE;&#xA;&#xA;IF EXISTS (SELECT 1 FROM sys.foreign_keys WHERE name = 'FK_FACT_VENTAS_DIM_TIME') &#xA;    ALTER TABLE dbo.FACT_VENTAS DROP CONSTRAINT FK_FACT_VENTAS_DIM_TIME;&#xA;&#xA;IF EXISTS (SELECT 1 FROM sys.foreign_keys WHERE name = 'FK_FACT_VENTAS_DIM_GEO') &#xA;    ALTER TABLE dbo.FACT_VENTAS DROP CONSTRAINT FK_FACT_VENTAS_DIM_GEO;&#xA;&#xA;IF EXISTS (SELECT 1 FROM sys.foreign_keys WHERE name = 'FK_FACT_VENTAS_DIM_DISCOUNT') &#xA;    ALTER TABLE dbo.FACT_VENTAS DROP CONSTRAINT FK_FACT_VENTAS_DIM_DISCOUNT;&#xA;&#xA;IF EXISTS (SELECT 1 FROM sys.foreign_keys WHERE name = 'FK_FACT_STOCK_DIM_TIME') &#xA;    ALTER TABLE dbo.FACT_stock DROP CONSTRAINT FK_FACT_STOCK_DIM_TIME;" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
      </DTS:ObjectData>
    </DTS:Executable>
    <DTS:Executable
      DTS:refId="Package\Generar y Cargar DIM_TIME 2"
      DTS:CreationName="Microsoft.ExecuteSQLTask"
      DTS:Description="Tarea Ejecutar SQL"
      DTS:Disabled="True"
      DTS:DTSID="{F0ED3865-294E-4A15-9803-CF77A7DEDA33}"
      DTS:ExecutableType="Microsoft.ExecuteSQLTask"
      DTS:LocaleID="-1"
      DTS:ObjectName="Generar y Cargar DIM_TIME 2"
      DTS:TaskContact="Execute SQL Task; Microsoft Corporation; SQL Server 2025; © 2025 Microsoft Corporation; All Rights Reserved;http://www.microsoft.com/sql/support/default.asp;1"
      DTS:ThreadHint="2">
      <DTS:Variables />
      <DTS:ObjectData>
        <SQLTask:SqlTaskData
          SQLTask:Connection="{BCEA2651-49FA-4687-BA94-3B74675C7F11}"
          SQLTask:SqlStatementSource="USE TDC_DataWarehouse;&#xA;GO&#xA;&#xA;-- Forzamos a que el primer día de la semana sea el Domingo&#xA;SET DATEFIRST 7;&#xA;&#xA;-- Usamos el formato universal YYYYMMDD sin guiones para evitar conflictos de idioma&#xA;DECLARE @StartDate DATE = '20000101';&#xA;DECLARE @EndDate DATE = '20151231';&#xA;&#xA;-- 1. Generamos todos los días secuenciales en memoria&#xA;WITH CalendarioBase AS (&#xA;    SELECT TOP (DATEDIFF(DAY, @StartDate, @EndDate) + 1)&#xA;        DATEADD(DAY, ROW_NUMBER() OVER (ORDER BY (SELECT NULL)) - 1, @StartDate) AS [Fecha]&#xA;    FROM sys.all_objects a CROSS JOIN sys.all_objects b&#xA;),&#xA;-- 2. Limpiamos y transformamos los números flotantes de Excel a fechas reales&#xA;FeriadosLimpios AS (&#xA;    SELECT DISTINCT&#xA;        -- 😎 Cambiamos '1899-12-30' por '18991230' para blindar la conversión en servidores en español&#xA;        DATEADD(day, CAST(CAST(TRIM([DATE]) AS FLOAT) AS INT), '18991230') AS [FechaFeriado]&#xA;    FROM dbo.STG_HOLIDAY&#xA;    WHERE [DATE] IS NOT NULL AND ISNUMERIC(TRIM([DATE])) = 1&#xA;)&#xA;-- 3. Insertamos directo en la dimensión final calculando las propiedades del JSON&#xA;INSERT INTO dbo.DIM_TIME (&#xA;    id_time,&#xA;    YYYYMMDD,&#xA;    [day],&#xA;    day_name,&#xA;    [month],&#xA;    month_day,&#xA;    [year],&#xA;    holiday,&#xA;    weekend,&#xA;    quarter,&#xA;    semester&#xA;)&#xA;SELECT &#xA;    C.[Fecha] AS [id_time],&#xA;    CONVERT(VARCHAR(10), C.[Fecha], 112) AS [YYYYMMDD], &#xA;    DATEPART(DAY, C.[Fecha]) AS [day],&#xA;    DATENAME(WEEKDAY, C.[Fecha]) AS [day_name], &#xA;    DATEPART(MONTH, C.[Fecha]) AS [month],&#xA;    DATENAME(MONTH, C.[Fecha]) AS [month_day], &#xA;    DATEPART(YEAR, C.[Fecha]) AS [year],&#xA;    &#xA;    CASE WHEN F.[FechaFeriado] IS NOT NULL THEN 1 ELSE 0 END AS [holiday],&#xA;    CASE WHEN DATEPART(WEEKDAY, C.[Fecha]) IN (1, 7) THEN 1 ELSE 0 END AS [weekend],&#xA;    DATEPART(QUARTER, C.[Fecha]) AS [quarter],&#xA;    CASE WHEN DATEPART(MONTH, C.[Fecha]) &lt;= 6 THEN 1 ELSE 2 END AS [semester]&#xA;&#xA;FROM CalendarioBase AS C&#xA;LEFT JOIN FeriadosLimpios AS F ON C.[Fecha] = F.[FechaFeriado];" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
      </DTS:ObjectData>
    </DTS:Executable>
    <DTS:Executable
      DTS:refId="Package\Inicializar tabla EMPLOYEE 2"
      DTS:CreationName="Microsoft.ExecuteSQLTask"
      DTS:Description="Tarea Ejecutar SQL"
      DTS:Disabled="True"
      DTS:DTSID="{A8034941-EDFD-4498-B569-E7E8697BF1BB}"
      DTS:ExecutableType="Microsoft.ExecuteSQLTask"
      DTS:LocaleID="-1"
      DTS:ObjectName="Inicializar tabla EMPLOYEE 2"
      DTS:TaskContact="Execute SQL Task; Microsoft Corporation; SQL Server 2025; © 2025 Microsoft Corporation; All Rights Reserved;http://www.microsoft.com/sql/support/default.asp;1"
      DTS:ThreadHint="1">
      <DTS:Variables />
      <DTS:ObjectData>
        <SQLTask:SqlTaskData
          SQLTask:Connection="{BCEA2651-49FA-4687-BA94-3B74675C7F11}"
          SQLTask:SqlStatementSource="USE TDC_DataWarehouse;&#xA;GO&#xA;&#xA;IF OBJECT_ID('dbo.DIM_EMPLOYEE', 'U') IS NOT NULL DROP TABLE dbo.DIM_EMPLOYEE;&#xA;IF OBJECT_ID('dbo.STG_EMPLOYEE', 'U') IS NOT NULL DROP TABLE dbo.STG_EMPLOYEE;&#xA;&#xA;-- La tabla intermedia ahora recibe el ID directamente como ENTERO&#xA;CREATE TABLE dbo.STG_EMPLOYEE (&#xA;    [employee_id] INT NULL,        &#xA;    [full_name] VARCHAR(255) NULL,&#xA;    [gender] VARCHAR(255) NULL,&#xA;    [category] VARCHAR(255) NULL,&#xA;    [employment_date] DATE NULL,      &#xA;    [birth_date] DATE NULL,            &#xA;    [education_level] VARCHAR(255) NULL&#xA;);&#xA;&#xA;CREATE TABLE dbo.DIM_EMPLOYEE (&#xA;    [employee_id] INT NOT NULL PRIMARY KEY, &#xA;    [full_name] VARCHAR(150) NOT NULL,&#xA;    [category] VARCHAR(100) NOT NULL,&#xA;    [employment_date] DATE NOT NULL,&#xA;    [birth_date] DATE NOT NULL,&#xA;    [education_level] VARCHAR(100) NOT NULL,&#xA;    [gender] VARCHAR(20) NOT NULL&#xA;);&#xA;&#xA;&#xA;BEGIN TRY&#xA;    SET IDENTITY_INSERT dbo.DIM_EMPLOYEE ON;&#xA;    INSERT INTO dbo.DIM_EMPLOYEE (employee_id, full_name, category, birth_date, employment_date, education_level, gender)&#xA;    VALUES (-1, 'Nombre desconocido', 'Categoria desconocida', '19000101', '19000101', 'Desconocido', 'NN');&#xA;    SET IDENTITY_INSERT dbo.DIM_EMPLOYEE OFF;&#xA;END TRY&#xA;BEGIN CATCH&#xA;    INSERT INTO dbo.DIM_EMPLOYEE (employee_id, full_name, category, birth_date, employment_date, education_level, gender)&#xA;    VALUES (-1, 'Nombre desconocido', 'Categoria desconocida', '19000101', '19000101', 'Desconocido', 'NN');&#xA;END CATCH;" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
      </DTS:ObjectData>
    </DTS:Executable>
    <DTS:Executable
      DTS:refId="Package\Inicializar tablas de TIME 2"
      DTS:CreationName="Microsoft.ExecuteSQLTask"
      DTS:DelayValidation="True"
      DTS:Description="Tarea Ejecutar SQL"
      DTS:Disabled="True"
      DTS:DTSID="{BD4B6033-4955-41D9-A074-C546AFF996F1}"
      DTS:ExecutableType="Microsoft.ExecuteSQLTask"
      DTS:LocaleID="-1"
      DTS:ObjectName="Inicializar tablas de TIME 2"
      DTS:TaskContact="Execute SQL Task; Microsoft Corporation; SQL Server 2025; © 2025 Microsoft Corporation; All Rights Reserved;http://www.microsoft.com/sql/support/default.asp;1"
      DTS:ThreadHint="2">
      <DTS:Variables />
      <DTS:ObjectData>
        <SQLTask:SqlTaskData
          SQLTask:Connection="{BCEA2651-49FA-4687-BA94-3B74675C7F11}"
          SQLTask:SqlStatementSource="USE TDC_DataWarehouse;&#xA;GO&#xA;&#xA;IF OBJECT_ID('dbo.DIM_TIME', 'U') IS NOT NULL DROP TABLE dbo.DIM_TIME;&#xA;IF OBJECT_ID('dbo.STG_HOLIDAY', 'U') IS NOT NULL DROP TABLE dbo.STG_HOLIDAY;&#xA;&#xA;-- 1. Tabla de Staging para absorber el CSV de feriados crudo&#xA;CREATE TABLE dbo.STG_HOLIDAY (&#xA;    [DATE] VARCHAR(100) NULL,&#xA;    [HOLIDAY] VARCHAR(255) NULL&#xA;);&#xA;&#xA;-- 2. Dimensión Final según tu JSON (BOOLEAN mapea a BIT en SQL Server)&#xA;CREATE TABLE dbo.DIM_TIME (&#xA;    [id_time] DATE NOT NULL PRIMARY KEY,&#xA;    [YYYYMMDD] VARCHAR(20) NOT NULL,&#xA;    [day] INT NOT NULL,&#xA;    [day_name] VARCHAR(30) NOT NULL,&#xA;    [month] INT NOT NULL,&#xA;    [month_day] VARCHAR(30) NOT NULL, -- Almacenará el nombre del mes descriptivo&#xA;    [year] INT NOT NULL,&#xA;    [holiday] BIT NOT NULL,&#xA;    [weekend] BIT NOT NULL,&#xA;    [quarter] INT NOT NULL,&#xA;    [semester] INT NOT NULL&#xA;);&#xA;&#xA;-- Inyectamos el miembro por defecto respetando de forma estricta los NOT NULL&#xA;IF NOT EXISTS (SELECT 1 FROM dbo.DIM_TIME WHERE id_time = '19000101')&#xA;BEGIN&#xA;    INSERT INTO dbo.DIM_TIME (&#xA;        [id_time], &#xA;        [YYYYMMDD], &#xA;        [day], &#xA;        [day_name], &#xA;        [month], &#xA;        [month_day], &#xA;        [year], &#xA;        [holiday], &#xA;        [weekend], &#xA;        [quarter], &#xA;        [semester]&#xA;    )&#xA;    VALUES (&#xA;        '19000101',           -- id_time (PK)&#xA;        '19000101',           -- YYYYMMDD&#xA;        -1,                    -- day&#xA;        'No Especificado',    -- day_name&#xA;        -1,                    -- month&#xA;        'No Especificado',    -- month_day&#xA;        1900,                 -- year&#xA;        0,                    -- holiday (BIT - Falso)&#xA;        0,                    -- weekend (BIT - Falso)&#xA;        -1,                    -- quarter&#xA;        -1                     -- semester&#xA;    );&#xA;END;" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
      </DTS:ObjectData>
    </DTS:Executable>
