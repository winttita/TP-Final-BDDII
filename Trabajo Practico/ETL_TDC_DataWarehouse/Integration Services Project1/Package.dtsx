        <DTS:Executable
          DTS:refId="Package\Contenedor DIM_TIME\Generar y Cargar DIM_TIME"
          DTS:CreationName="Microsoft.ExecuteSQLTask"
          DTS:Description="Tarea Ejecutar SQL"
          DTS:DTSID="{26f7ce1c-e0b3-49a9-a558-21697d1b32ff}"
          DTS:ExecutableType="Microsoft.ExecuteSQLTask"
          DTS:LocaleID="-1"
          DTS:ObjectName="Generar y Cargar DIM_TIME"
          DTS:TaskContact="Execute SQL Task; Microsoft Corporation; SQL Server 2025; © 2025 Microsoft Corporation; All Rights Reserved;http://www.microsoft.com/sql/support/default.asp;1"
          DTS:ThreadHint="0">
          <DTS:Variables />
          <DTS:ObjectData>
            <SQLTask:SqlTaskData
              SQLTask:Connection="{BCEA2651-49FA-4687-BA94-3B74675C7F11}"
              SQLTask:SqlStatementSource="USE TDC_DataWarehouse;&#xA;GO&#xA;&#xA;-- Forzamos a que el primer día de la semana sea el Domingo&#xA;SET DATEFIRST 7;&#xA;&#xA;-- Tu calendario estirado y óptimo&#xA;DECLARE @StartDate DATE = '20000101';&#xA;DECLARE @EndDate DATE = '20281231';&#xA;&#xA;-- 1. Generamos todos los días secuenciales en memoria&#xA;WITH CalendarioBase AS (&#xA;    SELECT TOP (DATEDIFF(DAY, @StartDate, @EndDate) + 1)&#xA;        DATEADD(DAY, ROW_NUMBER() OVER (ORDER BY (SELECT NULL)) - 1, @StartDate) AS [Fecha]&#xA;    FROM sys.all_objects a CROSS JOIN sys.all_objects b&#xA;),&#xA;-- 2. Procesamos de forma segura las fechas del driver de Excel&#xA;FeriadosLimpios AS (&#xA;    SELECT DISTINCT&#xA;        COALESCE(&#xA;            TRY_CONVERT(DATE, TRIM([DATE])),       &#xA;            TRY_CONVERT(DATE, TRIM([DATE]), 103),  &#xA;            TRY_CONVERT(DATE, TRIM([DATE]), 101),  &#xA;            CASE WHEN ISNUMERIC(TRIM([DATE])) = 1 THEN DATEADD(day, CAST(CAST(TRIM([DATE]) AS FLOAT) AS INT), '18991230') END&#xA;        ) AS [FechaFeriado]&#xA;    FROM dbo.STG_HOLIDAY&#xA;    WHERE [DATE] IS NOT NULL&#xA;)&#xA;-- 3. Insertamos los días que falten en la dimensión&#xA;INSERT INTO dbo.DIM_TIME (&#xA;    id_time, YYYYMMDD, [day], day_name, [month], month_day, [year], holiday, weekend, quarter, semester&#xA;)&#xA;SELECT &#xA;    C.[Fecha] AS [id_time],&#xA;    CONVERT(VARCHAR(10), C.[Fecha], 112) AS [YYYYMMDD], &#xA;    DATEPART(DAY, C.[Fecha]) AS [day],&#xA;    DATENAME(WEEKDAY, C.[Fecha]) AS [day_name], &#xA;    DATEPART(MONTH, C.[Fecha]) AS [month],&#xA;    DATENAME(MONTH, C.[Fecha]) AS [month_day], &#xA;    DATEPART(YEAR, C.[Fecha]) AS [year],&#xA;    0 AS [holiday], -- Nacen en 0 y abajo los encendemos todos en masa&#xA;    CASE WHEN DATEPART(WEEKDAY, C.[Fecha]) IN (1, 7) THEN 1 ELSE 0 END AS [weekend],&#xA;    DATEPART(QUARTER, C.[Fecha]) AS [quarter],&#xA;    CASE WHEN DATEPART(MONTH, C.[Fecha]) &lt;= 6 THEN 1 ELSE 2 END AS [semester]&#xA;FROM CalendarioBase AS C&#xA;WHERE NOT EXISTS (&#xA;    SELECT 1 FROM dbo.DIM_TIME WHERE id_time = C.[Fecha]&#xA;);&#xA;&#xA;-- 4. Inyectamos la fila maestra para Power BI si no existe&#xA;IF NOT EXISTS (SELECT 1 FROM dbo.DIM_TIME WHERE id_time = '19000101')&#xA;BEGIN&#xA;    INSERT INTO dbo.DIM_TIME (id_time, YYYYMMDD, [day], day_name, [month], month_day, [year], holiday, weekend, quarter, semester)&#xA;    VALUES ('19000101', '19000101', -1, 'No Especificado', -1, 'No Especificado', 1900, 0, 0, -1, -1);&#xA;END;&#xA;&#xA;-- ===================================================================&#xA;-- 5. 🌟 EXTRAPOLACIÓN MAESTRA POR DÍA Y MES (CON EXCEPCIÓN)&#xA;-- ===================================================================&#xA;WITH FeriadosTemplates AS (&#xA;    SELECT DISTINCT&#xA;        COALESCE(&#xA;            TRY_CONVERT(DATE, TRIM([DATE])),&#xA;            TRY_CONVERT(DATE, TRIM([DATE]), 103),&#xA;            TRY_CONVERT(DATE, TRIM([DATE]), 101),&#xA;            CASE WHEN ISNUMERIC(TRIM([DATE])) = 1 THEN DATEADD(day, CAST(CAST(TRIM([DATE]) AS FLOAT) AS INT), '18991230') END&#xA;        ) AS [FechaFeriado]&#xA;    FROM dbo.STG_HOLIDAY&#xA;    WHERE [DATE] IS NOT NULL&#xA;)&#xA;UPDATE T&#xA;SET T.[holiday] = 1&#xA;FROM dbo.DIM_TIME AS T&#xA;INNER JOIN FeriadosTemplates AS F &#xA;    ON DATEPART(DAY, T.[id_time]) = DATEPART(DAY, F.[FechaFeriado])   -- Mismo día &#xA;   AND DATEPART(MONTH, T.[id_time]) = DATEPART(MONTH, F.[FechaFeriado]) -- Mismo mes&#xA;WHERE T.[id_time] &lt;&gt; '19000101'; -- 🛡️ LA EXCEPCIÓN: Impedimos que toque la fila comodín&#xA;&#xA;" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
          </DTS:ObjectData>
        </DTS:Executable>
        <DTS:Executable
          DTS:refId="Package\Contenedor DIM_TIME\Inicializar tablas de TIME"
          DTS:CreationName="Microsoft.ExecuteSQLTask"
          DTS:DelayValidation="True"
          DTS:Description="Tarea Ejecutar SQL"
          DTS:DTSID="{bdf65e05-52ec-4efe-a7a6-b06adbfa2f26}"
          DTS:ExecutableType="Microsoft.ExecuteSQLTask"
          DTS:LocaleID="-1"
          DTS:ObjectName="Inicializar tablas de TIME"
          DTS:TaskContact="Execute SQL Task; Microsoft Corporation; SQL Server 2025; © 2025 Microsoft Corporation; All Rights Reserved;http://www.microsoft.com/sql/support/default.asp;1"
          DTS:ThreadHint="0">
          <DTS:Variables />
          <DTS:ObjectData>
            <SQLTask:SqlTaskData
              SQLTask:Connection="{BCEA2651-49FA-4687-BA94-3B74675C7F11}"
              SQLTask:SqlStatementSource="USE TDC_DataWarehouse;&#xA;GO&#xA;&#xA;IF OBJECT_ID('dbo.DIM_TIME', 'U') IS NOT NULL DROP TABLE dbo.DIM_TIME;&#xA;IF OBJECT_ID('dbo.STG_HOLIDAY', 'U') IS NOT NULL DROP TABLE dbo.STG_HOLIDAY;&#xA;&#xA;-- 1. Tabla de Staging para absorber el CSV de feriados crudo&#xA;CREATE TABLE dbo.STG_HOLIDAY (&#xA;    [DATE] VARCHAR(100) NULL,&#xA;    [HOLIDAY] VARCHAR(255) NULL&#xA;);&#xA;&#xA;-- 2. Dimensión Final según tu JSON (BOOLEAN mapea a BIT en SQL Server)&#xA;CREATE TABLE dbo.DIM_TIME (&#xA;    [id_time] DATE NOT NULL PRIMARY KEY,&#xA;    [YYYYMMDD] VARCHAR(20) NOT NULL,&#xA;    [day] INT NOT NULL,&#xA;    [day_name] VARCHAR(30) NOT NULL,&#xA;    [month] INT NOT NULL,&#xA;    [month_day] VARCHAR(30) NOT NULL, -- Almacenará el nombre del mes descriptivo&#xA;    [year] INT NOT NULL,&#xA;    [holiday] BIT NOT NULL,&#xA;    [weekend] BIT NOT NULL,&#xA;    [quarter] INT NOT NULL,&#xA;    [semester] INT NOT NULL&#xA;);&#xA;&#xA;-- Inyectamos el miembro por defecto respetando de forma estricta los NOT NULL&#xA;IF NOT EXISTS (SELECT 1 FROM dbo.DIM_TIME WHERE id_time = '19000101')&#xA;BEGIN&#xA;    INSERT INTO dbo.DIM_TIME (&#xA;        [id_time], &#xA;        [YYYYMMDD], &#xA;        [day], &#xA;        [day_name], &#xA;        [month], &#xA;        [month_day], &#xA;        [year], &#xA;        [holiday], &#xA;        [weekend], &#xA;        [quarter], &#xA;        [semester]&#xA;    )&#xA;    VALUES (&#xA;        '19000101',           -- id_time (PK)&#xA;        '19000101',           -- YYYYMMDD&#xA;        -1,                    -- day&#xA;        'No Especificado',    -- day_name&#xA;        -1,                    -- month&#xA;        'No Especificado',    -- month_day&#xA;        1900,                 -- year&#xA;        0,                    -- holiday (BIT - Falso)&#xA;        0,                    -- weekend (BIT - Falso)&#xA;        -1,                    -- quarter&#xA;        -1                     -- semester&#xA;    );&#xA;END;" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
