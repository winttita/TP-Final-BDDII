        <DTS:Executable
          DTS:refId="Package\Contenedor FACT_VENTAS\Inicializar tabla VENTAS"
          DTS:CreationName="Microsoft.ExecuteSQLTask"
          DTS:Description="Tarea Ejecutar SQL"
          DTS:DTSID="{7639D475-F7E6-4D8D-8004-F0179953542D}"
          DTS:ExecutableType="Microsoft.ExecuteSQLTask"
          DTS:LocaleID="-1"
          DTS:ObjectName="Inicializar tabla VENTAS"
          DTS:TaskContact="Execute SQL Task; Microsoft Corporation; SQL Server 2025; © 2025 Microsoft Corporation; All Rights Reserved;http://www.microsoft.com/sql/support/default.asp;1"
          DTS:ThreadHint="7">
          <DTS:Variables />
          <DTS:ObjectData>
            <SQLTask:SqlTaskData
              SQLTask:Connection="{BCEA2651-49FA-4687-BA94-3B74675C7F11}"
              SQLTask:SqlStatementSource="USE TDC_DataWarehouse;&#xA;GO&#xA;&#xA;IF OBJECT_ID('dbo.FACT_VENTAS', 'U') IS NOT NULL DROP TABLE dbo.FACT_VENTAS;&#xA;IF OBJECT_ID('dbo.STG_SALES', 'U') IS NOT NULL DROP TABLE dbo.STG_SALES;&#xA;&#xA;-- Tabla de Staging Adaptada (Solo las 7 columnas reales que comparten tus fuentes)&#xA;CREATE TABLE dbo.STG_SALES (&#xA;    [billing_id] INT NULL,&#xA;    [date] DATE NULL,&#xA;    [customer_id] INT NULL,&#xA;    [employee_id] INT NULL,&#xA;    [product_id] INT NULL,&#xA;    [quantity] INT NULL,&#xA;    [region] VARCHAR(100) NULL&#xA;);&#xA;&#xA;-- Tabla de Hechos Final (Mantiene el formato VARCHAR para el grupo etario)&#xA;CREATE TABLE dbo.FACT_VENTAS (&#xA;    [id_ventas] INT IDENTITY(1,1) NOT NULL PRIMARY KEY,&#xA;    [billing_id] INT NOT NULL,&#xA;    [id_time] DATE NOT NULL,          &#xA;    [id_geo] INT NOT NULL,           &#xA;    [id_customer] INT NOT NULL,      &#xA;    [id_prod] INT NOT NULL,          &#xA;    [id_employee] INT NOT NULL,      &#xA;    [quantity] INT NOT NULL,&#xA;    [unit_price] FLOAT NOT NULL,&#xA;    [gross_total_price] FLOAT NOT NULL,&#xA;    [id_discount] INT NOT NULL,      &#xA;    [discount] FLOAT NOT NULL,&#xA;    [sale_total_price] FLOAT NOT NULL,&#xA;    [lts_consumed] FLOAT NOT NULL,&#xA;    [age_customer] INT NOT NULL,&#xA;    [age_employee] INT NOT NULL,&#xA;    [seniority_employee] INT NOT NULL,&#xA;    [age_group] VARCHAR(50) NOT NULL&#xA;);" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
          </DTS:ObjectData>
        </DTS:Executable>
        <DTS:Executable
          DTS:refId="Package\Contenedor FACT_VENTAS\Transformar y Cargar FACT_VENTAS"
          DTS:CreationName="Microsoft.ExecuteSQLTask"
          DTS:Description="Tarea Ejecutar SQL"
          DTS:DTSID="{8365A2FD-45B3-44F5-BC14-EC77D6860617}"
          DTS:ExecutableType="Microsoft.ExecuteSQLTask"
          DTS:LocaleID="-1"
          DTS:ObjectName="Transformar y Cargar FACT_VENTAS"
          DTS:TaskContact="Execute SQL Task; Microsoft Corporation; SQL Server 2025; © 2025 Microsoft Corporation; All Rights Reserved;http://www.microsoft.com/sql/support/default.asp;1"
          DTS:ThreadHint="7">
          <DTS:Variables />
          <DTS:ObjectData>
            <SQLTask:SqlTaskData
              SQLTask:Connection="{BCEA2651-49FA-4687-BA94-3B74675C7F11}"
              SQLTask:SqlStatementSource="USE TDC_DataWarehouse;&#xA;GO&#xA;&#xA;-- 1. Estructura para el Fallback temporal de Productos (SCD2)&#xA;WITH DimProd_SCD2 AS (&#xA;    SELECT *,&#xA;           -- Numeramos las versiones cronológicas de cada artículo&#xA;           ROW_NUMBER() OVER(PARTITION BY product_id ORDER BY price_from ASC) AS rn_primero&#xA;    FROM dbo.DIM_PROD&#xA;),&#xA;-- 2. Buscamos el precio histórico o aplicamos contingencias si el ID o la fecha son NULL&#xA;VentasConPrecio AS (&#xA;    SELECT &#xA;        S.*,&#xA;        -- Si el product_id viene NULL o no acopla por fecha, rescata la primera versión o clava -1&#xA;        COALESCE(P_exacto.[id_dim_prod], P_primero.[id_dim_prod], -1) AS [id_prod_SCD2],&#xA;        CASE WHEN P_exacto.[id_dim_prod] IS NOT NULL THEN P_exacto.[price] ELSE 0 END AS [precio_unitario],&#xA;        ISNULL(COALESCE(P_exacto.[capacity], P_primero.[capacity]), 0) AS [capacidad_producto]&#xA;    FROM dbo.STG_SALES AS S&#xA;    LEFT JOIN dbo.DIM_PROD AS P_exacto ON S.[product_id] = P_exacto.[product_id] &#xA;        AND S.[date] BETWEEN P_exacto.[price_from] AND ISNULL(P_exacto.[price_until], '99991231')&#xA;    LEFT JOIN DimProd_SCD2 AS P_primero ON S.[product_id] = P_primero.[product_id] AND P_primero.rn_primero = 1&#xA;),&#xA;-- 3. Sumamos los totales de cada factura para evaluar contra la escala de mínimos de descuentos&#xA;TotalesFactura AS (&#xA;    SELECT &#xA;        billing_id,&#xA;        [date],&#xA;        SUM(quantity * precio_unitario) AS bruto_factura&#xA;    FROM VentasConPrecio&#xA;    GROUP BY billing_id, [date]&#xA;),&#xA;-- 4. EL FILTRO MAESTRO: Evaluamos qué descuentos aplican (incluido el -1 con mínimo 0) y elegimos el mejor&#xA;DescuentoElegido AS (&#xA;    SELECT &#xA;        T.billing_id,&#xA;        ISNULL(D.id_discount, -1) AS id_discount,&#xA;        ISNULL(D.discount_percentage, 0) AS discount_percentage,&#xA;        -- Ordenamos por porcentaje de forma descendente. El mayor beneficio tendrá el rn = 1&#xA;        ROW_NUMBER() OVER(PARTITION BY T.billing_id ORDER BY ISNULL(D.discount_percentage, 0) DESC) AS rn&#xA;    FROM TotalesFactura AS T&#xA;    LEFT JOIN dbo.DIM_DISCOUNT AS D ON T.bruto_factura &gt;= D.min_total_sale&#xA;        AND ISNULL(T.[date], '19000101') BETWEEN D.[from] AND ISNULL(D.[until], '99991231')&#xA;)&#xA;-- 5. Insertamos la totalidad de los datos limpios en la tabla de hechos final (100% de la recaudación)&#xA;INSERT INTO dbo.FACT_VENTAS (&#xA;    billing_id, id_time, id_geo, id_customer, id_prod, id_employee,&#xA;    quantity, unit_price, gross_total_price, id_discount, discount,&#xA;    sale_total_price, lts_consumed, age_customer, age_employee,&#xA;    seniority_employee, age_group&#xA;)&#xA;SELECT &#xA;    V.[billing_id],&#xA;    &#xA;    -- DIRECTIVA PROFESOR: Si la fecha original es NULL, viaja directo a la fecha fantasma '1900-01-01'&#xA;    TI.[id_time] AS [id_time], &#xA;    &#xA;    -- Doble escudo: si no hay cliente o no cruza código postal, se le asigna el -1 de Geografía&#xA;    ISNULL(G.[id_geo], -1) AS [id_geo],&#xA;    &#xA;    -- Si vienen nulos del Staging, viajan a los comodines de dimensiones que creamos en los pasos anteriores&#xA;    ISNULL(C.[id_customer], -1) AS [id_customer],&#xA;    V.[id_prod_SCD2] AS [id_prod],&#xA;    ISNULL(E.[employee_id], -1) AS [id_employee], &#xA;    &#xA;    V.[quantity],&#xA;    V.[precio_unitario] AS [unit_price],&#xA;    (V.[quantity] * V.[precio_unitario]) AS [gross_total_price],&#xA;    &#xA;    -- Traemos el ID del descuento ganador único para esta factura&#xA;    DE.[id_discount] AS [id_discount],&#xA;    &#xA;    ROUND((V.[quantity] * V.[precio_unitario]) * (DE.[discount_percentage] / 100.0), 2) AS [discount],&#xA;    ROUND((V.[quantity] * V.[precio_unitario]) * (1 - (DE.[discount_percentage] / 100.0)), 2) AS [sale_total_price],&#xA;    ROUND((V.[quantity] * V.[capacidad_producto]) / 1000.0, 2) AS [lts_consumed],&#xA;    &#xA;    -- Cálculos defensivos de edad: si la fecha de venta o nacimiento son NULL, DATEDIFF da NULL e impacta en -1&#xA;    ISNULL(DATEDIFF(YEAR, C.[birth_date], V.[date]), -1) AS [age_customer],&#xA;    ISNULL(DATEDIFF(YEAR, E.[birth_date], V.[date]), -1) AS [age_employee],&#xA;    ISNULL(DATEDIFF(YEAR, E.[employment_date], V.[date]), -1) AS [seniority_employee],&#xA;    &#xA;    CASE &#xA;        WHEN C.[birth_date] IS NULL OR V.[date] IS NULL THEN 'No Especificado'&#xA;        WHEN DATEDIFF(YEAR, C.[birth_date], V.[date]) BETWEEN 13 AND 19 THEN 'Adolescentes'&#xA;        WHEN DATEDIFF(YEAR, C.[birth_date], V.[date]) BETWEEN 20 AND 30 THEN 'Joven adulto'&#xA;        WHEN DATEDIFF(YEAR, C.[birth_date], V.[date]) BETWEEN 31 AND 40 THEN 'Adulto'&#xA;        WHEN DATEDIFF(YEAR, C.[birth_date], V.[date]) BETWEEN 41 AND 50 THEN 'Adultos medios'&#xA;        WHEN DATEDIFF(YEAR, C.[birth_date], V.[date]) BETWEEN 51 AND 60 THEN 'Adulto maduro'&#xA;        ELSE 'Adulto mayor'&#xA;    END AS [age_group]&#xA;&#xA;FROM VentasConPrecio AS V&#xA;&#xA;-- UNIÓN INMUNE A NULOS: Convertimos el NULL temporalmente en '19000101' para que acople con tu nueva fila de DIM_TIME&#xA;INNER JOIN dbo.DIM_TIME AS TI ON ISNULL(V.[date], '19000101') = TI.[id_time]&#xA;&#xA;LEFT JOIN dbo.DIM_CUSTOMER AS C ON V.[customer_id] = C.[id_customer]&#xA;LEFT JOIN dbo.DIM_EMPLOYEE AS E ON V.[employee_id] = E.[employee_id]&#xA;LEFT JOIN dbo.DIM_GEO AS G ON TRIM(C.[zipcode]) = TRIM(G.[zipcode])&#xA;-- Acoplamos contra el descuento ganador único filtrado por la ventana analítica (rn = 1)&#xA;INNER JOIN DescuentoElegido AS DE ON V.[billing_id] = DE.[billing_id] AND DE.rn = 1;" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
          </DTS:ObjectData>
        </DTS:Executable>
      </DTS:Executables>
