        <DTS:Executable
          DTS:refId="Package\Contenedor FACT_STOCK\Transformar y Cargar FACT_STOCK"
          DTS:CreationName="Microsoft.ExecuteSQLTask"
          DTS:Description="Tarea Ejecutar SQL"
          DTS:DTSID="{A5E42539-C157-4318-AD51-D508EA10C0E8}"
          DTS:ExecutableType="Microsoft.ExecuteSQLTask"
          DTS:LocaleID="-1"
          DTS:ObjectName="Transformar y Cargar FACT_STOCK"
          DTS:TaskContact="Execute SQL Task; Microsoft Corporation; SQL Server 2025; © 2025 Microsoft Corporation; All Rights Reserved;http://www.microsoft.com/sql/support/default.asp;1"
          DTS:ThreadHint="6">
          <DTS:Variables />
          <DTS:ObjectData>
            <SQLTask:SqlTaskData
              SQLTask:Connection="{BCEA2651-49FA-4687-BA94-3B74675C7F11}"
              SQLTask:SqlStatementSource="USE TDC_DataWarehouse;&#xA;GO&#xA;&#xA;-- 1. Slicing estratégico: Extraemos solo los primeros 10 caracteres (MM/DD/YYYY) e ignoramos la hora corrupta&#xA;WITH StockConFechaLimpia AS (&#xA;    SELECT &#xA;        [id_stg],&#xA;        [product_id],&#xA;        [variation],&#xA;        -- El estilo 101 le dice a SQL: &quot;Leé esto como MM/DD/YYYY de forma obligatoria&quot;&#xA;        CONVERT(DATE, LEFT(TRIM([date_str]), 10), 101) AS [id_time_date]&#xA;    FROM dbo.STG_STOCK&#xA;),&#xA;-- 2. Calculamos el stock acumulado progresivo usando el ID de entrada para mantener el orden fiel del TXT&#xA;StockCalculado AS (&#xA;    SELECT &#xA;        [product_id],&#xA;        [id_time_date],&#xA;        [variation],&#xA;        -- Suma acumulativa perfecta basada en el orden de llegada de las filas&#xA;        SUM([variation]) OVER(&#xA;            PARTITION BY [product_id] &#xA;            ORDER BY [id_stg] ASC&#xA;        ) AS [quantity_acumulada]&#xA;    FROM StockConFechaLimpia&#xA;)&#xA;-- 3. Insertamos en la tabla de hechos definitiva acoplando contra tu DIM_TIME&#xA;INSERT INTO dbo.FACT_stock ([id_product], [id_time], [quantity_acum], [variation])&#xA;SELECT &#xA;    S.[product_id] AS [id_product],&#xA;    TI.[id_time] AS [id_time],&#xA;    S.[quantity_acumulada] AS [quantity_acum],&#xA;    S.[variation] AS [variation]&#xA;FROM StockCalculado AS S&#xA;INNER JOIN dbo.DIM_TIME AS TI ON S.[id_time_date] = TI.[id_time]&#xA;ORDER BY S.[product_id], S.[id_time_date];" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
          </DTS:ObjectData>
        </DTS:Executable>
      </DTS:Executables>
