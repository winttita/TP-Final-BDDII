        <DTS:Executable
          DTS:refId="Package\Contenedor DIM_EMPLOYEE\Inicializar tabla EMPLOYEE"
          DTS:CreationName="Microsoft.ExecuteSQLTask"
          DTS:Description="Tarea Ejecutar SQL"
          DTS:DTSID="{50ac821c-5a0d-4010-8ce1-0d6ea23fee91}"
          DTS:ExecutableType="Microsoft.ExecuteSQLTask"
          DTS:LocaleID="-1"
          DTS:ObjectName="Inicializar tabla EMPLOYEE"
          DTS:TaskContact="Execute SQL Task; Microsoft Corporation; SQL Server 2025; © 2025 Microsoft Corporation; All Rights Reserved;http://www.microsoft.com/sql/support/default.asp;1"
          DTS:ThreadHint="0">
          <DTS:Variables />
          <DTS:ObjectData>
            <SQLTask:SqlTaskData
              SQLTask:Connection="{BCEA2651-49FA-4687-BA94-3B74675C7F11}"
              SQLTask:SqlStatementSource="USE TDC_DataWarehouse;&#xA;GO&#xA;&#xA;IF OBJECT_ID('dbo.DIM_EMPLOYEE', 'U') IS NOT NULL DROP TABLE dbo.DIM_EMPLOYEE;&#xA;IF OBJECT_ID('dbo.STG_EMPLOYEE', 'U') IS NOT NULL DROP TABLE dbo.STG_EMPLOYEE;&#xA;&#xA;-- La tabla intermedia&#xA;CREATE TABLE dbo.STG_EMPLOYEE (&#xA;    [employee_id] INT NULL,        &#xA;    [full_name] VARCHAR(255) NULL,&#xA;    [gender] VARCHAR(255) NULL,&#xA;    [category] VARCHAR(255) NULL,&#xA;    [employment_date] DATE NULL,      &#xA;    [birth_date] DATE NULL,            &#xA;    [education_level] VARCHAR(255) NULL&#xA;);&#xA;&#xA;-- La dimensión final con tu nuevo estándar id_employee&#xA;CREATE TABLE dbo.DIM_EMPLOYEE (&#xA;    [id_employee] INT NOT NULL PRIMARY KEY, &#xA;    [full_name] VARCHAR(150) NOT NULL,&#xA;    [category] VARCHAR(100) NOT NULL,&#xA;    [employment_date] DATE NOT NULL,&#xA;    [birth_date] DATE NOT NULL,&#xA;    [education_level] VARCHAR(100) NOT NULL,&#xA;    [gender] VARCHAR(20) NOT NULL&#xA;);&#xA;&#xA;-- TRUCO MAESTRO: Usamos EXEC para engañar al compilador y que no valide la columna hasta que la tabla se cree&#xA;EXEC('&#xA;    INSERT INTO dbo.DIM_EMPLOYEE (id_employee, full_name, category, birth_date, employment_date, education_level, gender)&#xA;    VALUES (-1, ''Nombre desconocido'', ''Categoria desconocida'', ''19000101'', ''19000101'', ''Desconocido'', ''NN'');&#xA;');" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
          </DTS:ObjectData>
        </DTS:Executable>
        <DTS:Executable
          DTS:refId="Package\Contenedor DIM_EMPLOYEE\Transformar y Cargar DIM_EMPLOYEE"
          DTS:CreationName="Microsoft.ExecuteSQLTask"
          DTS:Description="Tarea Ejecutar SQL"
          DTS:DTSID="{719a79fd-c2e8-4a2f-8b33-daa5b69a98a8}"
          DTS:ExecutableType="Microsoft.ExecuteSQLTask"
          DTS:LocaleID="-1"
          DTS:ObjectName="Transformar y Cargar DIM_EMPLOYEE"
          DTS:TaskContact="Execute SQL Task; Microsoft Corporation; SQL Server 2025; © 2025 Microsoft Corporation; All Rights Reserved;http://www.microsoft.com/sql/support/default.asp;1"
          DTS:ThreadHint="0">
          <DTS:Variables />
          <DTS:ObjectData>
            <SQLTask:SqlTaskData
              SQLTask:Connection="{BCEA2651-49FA-4687-BA94-3B74675C7F11}"
              SQLTask:SqlStatementSource="USE TDC_DataWarehouse;&#xA;GO&#xA;&#xA;INSERT INTO dbo.DIM_EMPLOYEE (&#xA;    id_employee, -- Tu columna normalizada 🌟&#xA;    full_name, &#xA;    category, &#xA;    birth_date, &#xA;    employment_date, &#xA;    education_level, &#xA;    gender&#xA;)&#xA;SELECT DISTINCT&#xA;    STG.[employee_id],&#xA;    ISNULL(STG.[full_name], 'Nombre desconocido'),&#xA;    ISNULL(STG.[category], 'Categoria desconocida'),&#xA;    STG.[birth_date],&#xA;    STG.[employment_date],&#xA;    ISNULL(STG.[education_level], 'Desconocido'),&#xA;    ISNULL(STG.[gender], 'NN')&#xA;FROM dbo.STG_EMPLOYEE AS STG&#xA;-- El escudo definitivo anti-basura de Excel&#xA;WHERE STG.[employee_id] IS NOT NULL&#xA;  -- Evitamos colisionar con el -1 o duplicar datos si re-ejecutás el trencito&#xA;  AND NOT EXISTS (&#xA;      SELECT 1 FROM dbo.DIM_EMPLOYEE AS DIM&#xA;      WHERE DIM.id_employee = STG.employee_id&#xA;  );" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
          </DTS:ObjectData>
        </DTS:Executable>
      </DTS:Executables>
